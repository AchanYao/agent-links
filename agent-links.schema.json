{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "targets"],
  "properties": {
    "$schema": { "type": "string" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agentsFile", "skillsDir"],
      "properties": {
        "agentsFile": { "type": "string" },
        "skillsDir": { "type": "string" }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "agentsFile": { "type": "string" },
          "skillsDir": { "type": "string" },
          "platforms": {
            "type": "array",
            "items": {
              "enum": ["aix", "android", "darwin", "freebsd", "haiku", "linux", "openbsd", "sunos", "win32", "cygwin", "netbsd"]
            }
          },
          "enabled": { "type": "boolean" }
        },
        "anyOf": [
          { "required": ["agentsFile"] },
          { "required": ["skillsDir"] }
        ]
      }
    }
  }
}
